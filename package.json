{
  "name": "bloomreach-buddy",
  "version": "0.0.1",
  "description": "AI-powered Bloomreach integration toolkit",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build",
    "test": "npm test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigvardt/bloomreach-buddy.git"
  },
  "author": "Joakim Sigvardt",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
